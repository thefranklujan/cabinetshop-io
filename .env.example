# CabinetShop.io — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local (it is gitignored).
# Values are intentionally omitted here.

# --- Supabase (required) ---
# Project: CabinetShop.io (ref ibarpcoigmpnicljeyzu). Public client config (safe in the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App ---
# Absolute base URL used to build email tracking/unsubscribe links. Defaults to https://cabinetshop.io if unset.
NEXT_PUBLIC_APP_URL=

# --- Email (platform admin campaigns; required only to send outreach) ---
# Resend API key used by /api/platform/campaigns/send.
RESEND_API_KEY=

# --- Tracking signatures (required for signed open/click/unsubscribe links) ---
# HMAC secret used by src/lib/tracking-sig.ts to sign tracking params. Generate a long random string.
TRACKING_HMAC_SECRET=
